{
  "_version": "1.82.0",
  "sap.app": {
    "id": "leave",
    "type": "application",
    "i18n": "i18n/i18n.properties",
    "applicationVersion": {
      "version": "0.0.1"
    },
    "title": "{{appTitle}}",
    "description": "{{appDescription}}",
    "resources": "resources.json",
    "sourceTemplate": {
      "id": "@sap/generator-fiori:lrop",
      "version": "1.20.3",
      "toolsId": "521d4878-6e61-44a8-b300-9e854b223687"
    },
    "dataSources": {
      "mainService": {
        "uri": "/odata/v4/leave/",
        "type": "OData",
        "settings": {
          "annotations": [],
          "odataVersion": "4.01"
        }
      }
    }
  },
  "sap.ui": {
    "technology": "UI5",
    "icons": {
      "icon": "",
      "favIcon": "",
      "phone": "",
      "phone@2": "",
      "tablet": "",
      "tablet@2": ""
    },
    "deviceTypes": {
      "desktop": true,
      "tablet": true,
      "phone": true
    }
  },
  "sap.ui5": {
    "flexEnabled": true,
    "dependencies": {
      "minUI5Version": "1.145.0",
      "libs": {
        "sap.m": {},
        "sap.ui.core": {},
        "sap.fe.templates": {}
      }
    },
    "contentDensities": {
      "compact": true,
      "cozy": true
    },
    "models": {
      "i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "settings": {
          "bundleName": "leave.i18n.i18n"
        }
      },
      "": {
        "dataSource": "mainService",
        "preload": true,
        "settings": {
          "operationMode": "Server",
          "autoExpandSelect": true,
          "earlyRequests": true
        }
      },
      "@i18n": {
        "type": "sap.ui.model.resource.ResourceModel",
        "uri": "i18n/i18n.properties"
      }
    },
    "resources": {
      "css": []
    },
    "routing": {
      "config": {},
      "routes": [
        {
          "pattern": ":?query:",
          "name": "LeaveRequestsList",
          "target": "LeaveRequestsList"
        },
        {
          "pattern": "LeaveRequests({key}):?query:",
          "name": "LeaveRequestsObjectPage",
          "target": "LeaveRequestsObjectPage"
        }
      ],
      "targets": {
        "LeaveRequestsList": {
          "type": "Component",
          "id": "LeaveRequestsList",
          "name": "sap.fe.templates.ListReport",
          "options": {
            "settings": {
              "contextPath": "/LeaveRequests",
              "variantManagement": "Page",
              "navigation": {
                "LeaveRequests": {
                  "detail": {
                    "route": "LeaveRequestsObjectPage"
                  }
                }
              },
              "controlConfiguration": {
                "@com.sap.vocabularies.UI.v1.LineItem": {
                  "tableSettings": {
                    "type": "ResponsiveTable",
                    "personalization": {
                      "filter": true,
                      "column": true,
                      "sort": true
                    },
                    "quickVariantSelection": {
                      "showCounts": true
                    },
                    "condensedTableLayout": true,
                    "enableExport": true,
                    "popinLayout": "GridLarge",
                    "selectionLimit": 5,
                    "widthIncludingColumnHeader": true,
                    "creationMode": {
                      "name": "NewPage"
                    }
                  }
                }
              },
              "initialLoad": "Enabled"
            }
          }
        },
        "LeaveRequestsObjectPage": {
          "type": "Component",
          "id": "LeaveRequestsObjectPage",
          "name": "sap.fe.templates.ObjectPage",
          "options": {
            "settings": {
              "editableHeaderContent": true,
              "contextPath": "/LeaveRequests",
              "content": {
                "header": {
                  "visible": true
                }
              },
              "showRelatedApps": true,
              "sectionLayout": "Page"
            }
          }
        }
      }
    }
  },
  "sap.fiori": {
    "registrationIds": [],
    "archeType": "transactional"
  },
  "sap.fe": {
    "app": {
      "enableLazyLoading": true
    }
  }
}
