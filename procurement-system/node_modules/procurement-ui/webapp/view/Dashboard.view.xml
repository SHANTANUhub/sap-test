<mvc:View
    controllerName="procurementui.controller.Dashboard"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:viz="sap.viz.ui5.controls"
    xmlns:viz.data="sap.viz.ui5.data"
    xmlns:viz.feeds="sap.viz.ui5.controls.common.feeds"
    xmlns:layout="sap.ui.layout"
    xmlns:core="sap.ui.core">

    <Page title="Smart Procurement Management" backgroundDesign="List">
        <content>
            <VBox width="95%" class="sapUiMediumMargin">

                <!-- KPI CARDS ROW -->
                <layout:Grid
                    defaultSpan="XL3 L3 M6 S12"
                    hSpacing="1"
                    vSpacing="1"
                    class="sapUiSmallMarginBottom">

                    <GenericTile
                        header="Total Requests"
                        frameType="OneByOne"
                        press="onTotalTilePress"
                        class="sapUiTinyMargin">
                        <TileContent>
                            <NumericContent
                                value="{kpi>/total}"
                                icon="sap-icon://document-text"
                                withMargin="false"/>
                        </TileContent>
                    </GenericTile>

                    <GenericTile
                        header="Approved Requests"
                        frameType="OneByOne"
                        press="onApprovedTilePress"
                        class="sapUiTinyMargin">
                        <TileContent>
                            <NumericContent
                                value="{kpi>/approved}"
                                valueColor="Good"
                                withMargin="false"/>
                        </TileContent>
                    </GenericTile>

                    <GenericTile
                        header="Pending Requests"
                        frameType="OneByOne"
                        press="onPendingTilePress"
                        class="sapUiTinyMargin">
                        <TileContent>
                            <NumericContent
                                value="{kpi>/pending}"
                                valueColor="Critical"
                                withMargin="false"/>
                        </TileContent>
                    </GenericTile>

                    <GenericTile
                        header="Rejected Requests"
                        frameType="OneByOne"
                        press="onRejectedTilePress"
                        class="sapUiTinyMargin">
                        <TileContent>
                            <NumericContent
                                value="{kpi>/rejected}"
                                valueColor="Error"
                                withMargin="false"/>
                        </TileContent>
                    </GenericTile>

                </layout:Grid>

                <!-- CHARTS ROW -->
                <layout:Grid
                    defaultSpan="XL4 L4 M12 S12"
                    hSpacing="1"
                    vSpacing="0"
                    class="sapUiSmallMarginTop sapUiSmallMarginBottom">

                    <!-- Department Bar Chart -->
                    <Panel headerText="Requests by Department" expandable="false">
                        <viz:VizFrame
                            vizType="column"
                            width="100%"
                            height="300px"
                            id="deptChart"
                            selectData="onDeptChartClick">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{chart>/departmentData}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition
                                            name="Department"
                                            value="{chart>department}"/>
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition
                                            name="Requests"
                                            value="{chart>count}"/>
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis"    type="Measure"   values="Requests"/>
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Department"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </Panel>

                    <!-- Monthly Spend Line Chart -->
                    <Panel headerText="Monthly Spend Overview" expandable="false">
                        <viz:VizFrame
                            vizType="line"
                            width="100%"
                            height="300px"
                            id="spendChart">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{chart>/monthlySpend}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition
                                            name="Month"
                                            value="{chart>month}"/>
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition
                                            name="Spend"
                                            value="{chart>amount}"/>
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="valueAxis"    type="Measure"   values="Spend"/>
                                <viz.feeds:FeedItem uid="categoryAxis" type="Dimension" values="Month"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </Panel>

                    <!-- Vendor Donut Chart -->
                    <Panel headerText="Top Vendors by Spend" expandable="false">
                        <viz:VizFrame
                            vizType="donut"
                            width="100%"
                            height="300px"
                            id="vendorChart"
                            selectData="onVendorChartClick">
                            <viz:dataset>
                                <viz.data:FlattenedDataset data="{chart>/vendorSpend}">
                                    <viz.data:dimensions>
                                        <viz.data:DimensionDefinition
                                            name="Vendor"
                                            value="{chart>vendor}"/>
                                    </viz.data:dimensions>
                                    <viz.data:measures>
                                        <viz.data:MeasureDefinition
                                            name="Amount"
                                            value="{chart>amount}"/>
                                    </viz.data:measures>
                                </viz.data:FlattenedDataset>
                            </viz:dataset>
                            <viz:feeds>
                                <viz.feeds:FeedItem uid="size"  type="Measure"   values="Amount"/>
                                <viz.feeds:FeedItem uid="color" type="Dimension" values="Vendor"/>
                            </viz:feeds>
                        </viz:VizFrame>
                    </Panel>

                </layout:Grid>

                <!-- QUICK NAVIGATION TILES -->
                <layout:Grid
                    defaultSpan="XL3 L3 M6 S12"
                    hSpacing="2"
                    vSpacing="1"
                    class="sapUiSmallMarginTop">

                    <GenericTile
                        header="Procurement Requests"
                        subheader="Manage Requests"
                        press="onNavToProcurement"
                        frameType="OneByOne"
                        style="max-width: 200px;"
                        class="sapUiTinyMargin">
                        <TileContent>
                            <ImageContent src="sap-icon://document-text"/>
                        </TileContent>
                    </GenericTile>

                    <GenericTile
                        header="Vendor Management"
                        subheader="View Vendors"
                        press="onNavToVendors"
                        frameType="OneByOne"
                        style="max-width: 200px;"
                        class="sapUiTinyMargin">
                        <TileContent>
                            <ImageContent src="sap-icon://supplier"/>
                        </TileContent>
                    </GenericTile>

                    <GenericTile
                        header="Product Catalog"
                        subheader="Browse Products"
                        press="onNavToCatalog"
                        frameType="OneByOne"
                        style="max-width: 200px;"
                        class="sapUiTinyMargin">
                        <TileContent>
                            <ImageContent src="sap-icon://product"/>
                        </TileContent>
                    </GenericTile>

                    <GenericTile
                        header="Reports"
                        subheader="View Reports"
                        press="onNavToReports"
                        frameType="OneByOne"
                        style="max-width: 200px;"
                        class="sapUiTinyMargin">
                        <TileContent>
                            <ImageContent src="sap-icon://bar-chart"/>
                        </TileContent>
                    </GenericTile>

                </layout:Grid>

            </VBox>
        </content>
    </Page>
</mvc:View>